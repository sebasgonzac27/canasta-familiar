{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "canasta-familiar",
  "compatibility_date": "2026-06-09",
  // Static-assets-only Worker: serves the Expo web export in ./dist.
  // The app is an SPA (app.json -> web.output: "single"), so unmatched
  // routes fall back to index.html for client-side (expo-router) routing.
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
